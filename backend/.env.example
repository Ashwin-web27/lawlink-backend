# Indian Education Law Chatbot - Backend Environment Configuration

# ===== SERVER CONFIGURATION =====
# FastAPI server settings
HOST=127.0.0.1
PORT=5000
DEBUG=true
RELOAD=true

# CORS Settings (already configured in main.py)
ALLOWED_ORIGINS=["https://law.skyzin.com", "https://law.skyzin.com", "https://llm.skyzin.com", "https://llm.skyzin.com"]

# ===== DATABASE CONFIGURATION =====
# If using a database (optional for future use)
# DATABASE_URL=sqlite:///./legal_chatbot.db
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=legal_chatbot
# DATABASE_USER=admin
# DATABASE_PASSWORD=your_password

# ===== AI/ML CONFIGURATION =====
# Model settings
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
VECTOR_DIMENSION=384
MAX_SEARCH_RESULTS=10
SIMILARITY_THRESHOLD=0.1

# Model paths (relative to dataset/)
VECTOR_INDEX_PATH=vector-database/legal_docs_index.index
PROCESSED_DOCS_PATH=processed-data/processed_legal_docs.json
MODELS_PATH=models/

# ===== CACHING CONFIGURATION =====
# Query caching
QUERY_CACHE_SIZE=500
QUERY_CACHE_TTL=1800  # 30 minutes in seconds
ENABLE_QUERY_CACHE=true

# ===== LOGGING CONFIGURATION =====
# Log levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FILE=system.log
ENABLE_FILE_LOGGING=true
LOG_MAX_SIZE=10485760  # 10MB
LOG_BACKUP_COUNT=3

# ===== API CONFIGURATION =====
# API documentation
API_TITLE="Indian Education Law Chatbot API"
API_DESCRIPTION="API for searching and querying Indian education law documents"
API_VERSION="1.0.0"
DOCS_URL="/docs"
REDOC_URL="/redoc"

# Rate limiting (if implemented)
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_PERIOD=3600  # per hour

# ===== SECURITY CONFIGURATION =====
# API Keys (if needed for external services)
# OPENAI_API_KEY=your_openai_key_here
# HUGGINGFACE_API_KEY=your_hf_key_here

# JWT Configuration (if implementing authentication)
# SECRET_KEY=your_super_secret_key_here
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===== LEGAL SYSTEM CONFIGURATION =====
# Legal document processing
DEFAULT_DOCUMENT_YEAR=1950
DEFAULT_LEGAL_DISCLAIMER="This system provides information from Indian education law sources. It is not a substitute for professional legal advice."

# Dataset configuration
DATASET_PATH=../dataset
LEGAL_DOCUMENTS_PATH=legal-documents
PROCESSED_DATA_PATH=processed-data
TRAINING_DATA_PATH=training-data

# ===== PERFORMANCE CONFIGURATION =====
# Processing settings
MAX_WORKERS=4
BATCH_SIZE=32
MAX_CONTENT_LENGTH=10000  # characters

# Memory management
MAX_MEMORY_USAGE=1000  # MB
ENABLE_MEMORY_MONITORING=true

# ===== DEVELOPMENT SETTINGS =====
# Development flags
DEVELOPMENT_MODE=true
ENABLE_DEBUG_ENDPOINTS=true
MOCK_RESPONSES=false

# Testing
RUN_TESTS_ON_STARTUP=false
ENABLE_TEST_DATA=false

# ===== MONITORING & ANALYTICS =====
# Health check settings
HEALTH_CHECK_INTERVAL=300  # 5 minutes
ENABLE_METRICS=true

# External monitoring (if needed)
# PROMETHEUS_ENABLED=false
# GRAFANA_ENABLED=false

# Error tracking (if needed)
# SENTRY_DSN=your_sentry_dsn_here
# SENTRY_ENVIRONMENT=development

# ===== INSTRUCTIONS =====
# 1. Copy this file to .env in the backend directory
# 2. Update the values as needed for your environment
# 3. Never commit the actual .env file to version control
# 4. The .env file is already ignored by .gitignore
#
# Most settings have sensible defaults in the code,
# so you only need to set values that differ from defaults.